# Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Web3.Storage IPFS Provider =====
# Get free token from: https://web3.storage
# 1. Sign up at https://web3.storage
# 2. Go to Account -> Create API Token
# 3. Copy token and paste below
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# ===== Blockchain Configuration =====
# Choose ONE option: Ganache (local) OR Sepolia (testnet)

# OPTION 1: Ganache Local Blockchain (RECOMMENDED for development)
# - UNLIMITED transactions (no faucet needed!)
# - Instant mining (0ms blocks)
# - FREE (no testnet ETH required)
# Steps:
#   1. Download Ganache: https://trufflesuite.com/ganache/
#   2. Click "Quickstart" (runs on http://127.0.0.1:8545)
#   3. Deploy: cd contracts && npm run deploy:local
#   4. Copy contract address below

BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
RELAYER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
INCIDENT_REGISTRY_CONTRACT_ADDRESS=

# OPTION 2: Ethereum Sepolia Testnet (for production testing)
# - Limited transactions (faucet limits apply)
# - 12 second blocks
# - Requires testnet ETH from faucet
# Get free RPC from Infura or Alchemy
# Infura: https://infura.io (sign up -> create project -> copy Sepolia endpoint)
# Alchemy: https://alchemy.com (similar process)
# Example: https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
# RELAYER_PRIVATE_KEY=0xyour_private_key_here
# INCIDENT_REGISTRY_CONTRACT_ADDRESS=

# To create a wallet for Sepolia:
# 1. Run: python -c "from eth_account import Account; acc = Account.create(); print(f'Address: {acc.address}\nPrivate Key: {acc.key.hex()}')"
# 2. Fund from faucet: https://sepoliafaucet.com

# ===== Smart Contract Address =====
# After deploying IncidentRegistry.sol to Sepolia, paste contract address here
# Example: 0x1234567890123456789012345678901234567890
INCIDENT_REGISTRY_CONTRACT_ADDRESS=
